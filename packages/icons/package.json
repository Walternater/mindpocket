{
  "name": "@repo/icons",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./web": {
      "types": "./src/web.tsx",
      "default": "./src/web.tsx"
    },
    "./native": {
      "types": "./src/native.tsx",
      "default": "./src/native.tsx"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/types": "workspace:*"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "typescript": "^5.5.4"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-native-svg": ">=15"
  },
  "peerDependenciesMeta": {
    "react-native-svg": {
      "optional": true
    }
  }
